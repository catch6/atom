  <groupId>cn.mindit</groupId>
  <artifactId>atom-dependencies</artifactId>
  <version>${revision}</version>
  <packaging>pom</packaging>

  <name>atom-dependencies</name>
  <description>Atom 依赖 BOM，统一管理 atom 各模块及常用第三方库的版本，可通过 dependencyManagement import 的方式引入。</description>
  <url>https://github.com/catch6/atom</url>

  <licenses>
    <license>
      <name>Mulan Permissive Software License, Version 2</name>
      <url>https://license.coscl.org.cn/MulanPSL2</url>
      <distribution>repo</distribution>
    </license>
  </licenses>

  <scm>
    <url>https://github.com/catch6/atom</url>
    <connection>scm:git:git://github.com/catch6/atom.git</connection>
    <developerConnection>scm:git:ssh://git@github.com/catch6/atom.git</developerConnection>
  </scm>

  <developers>
    <developer>
      <id>Catch</id>
      <name>Catch</name>
      <email>catchlife6@163.com</email>
      <url>https://github.com/catch6</url>
      <roles>
        <role>Developer</role>
      </roles>
      <timezone>+8</timezone>
    </developer>
  </developers>

  <properties>
    <revision>4.0.0</revision>

    <spring-cloud.version>2025.1.1</spring-cloud.version>
    <spring-cloud-alibaba.version>2025.1.0.0</spring-cloud-alibaba.version>
    <spring-modulith.version>2.0.5</spring-modulith.version>
    <spring-ai.version>2.0.0-M4</spring-ai.version>

    <mybatis-plus.version>3.5.16</mybatis-plus.version>
    <spring-boot-starter-aop.version>4.0.0-M2</spring-boot-starter-aop.version>
    <nimbus-jose-jwt.version>10.9</nimbus-jose-jwt.version>
    <hutool-all.version>5.8.44</hutool-all.version>
    <guava.version>33.6.0-jre</guava.version>
    <springdoc-openapi-starter-webmvc-ui.version>3.0.3</springdoc-openapi-starter-webmvc-ui.version>
    <swagger-annotations-jakarta.version>2.2.48</swagger-annotations-jakarta.version>
    <fastexcel.version>1.3.0</fastexcel.version>
    <logback-adapter.version>1.1.4</logback-adapter.version>
    <mapstruct.version>1.6.3</mapstruct.version>
    <mapstruct-plus.version>1.5.0</mapstruct-plus.version>
    <httpclient5.version>5.6</httpclient5.version>
    <org.eclipse.paho.client.mqttv3.version>1.2.5</org.eclipse.paho.client.mqttv3.version>
    <org.eclipse.paho.mqttv5.client.version>1.2.5</org.eclipse.paho.mqttv5.client.version>
    <org.openscada.opc.lib.version>1.5.0</org.openscada.opc.lib.version>
    <bcprov-jdk15on.version>1.70</bcprov-jdk15on.version>
    <milo.version>0.6.16</milo.version>
    <j-interop.version>2.0.4</j-interop.version>
    <shedlock.version>7.7.0</shedlock.version>
  </properties>

  <dependencyManagement>
    <dependencies>
      <!-- 外部 BOM -->
      <dependency>
        <groupId>org.springframework.cloud</groupId>
        <artifactId>spring-cloud-dependencies</artifactId>
        <version>${spring-cloud.version}</version>
        <type>pom</type>
        <scope>import</scope>
      </dependency>
      <dependency>
        <groupId>com.alibaba.cloud</groupId>
        <artifactId>spring-cloud-alibaba-dependencies</artifactId>
        <version>${spring-cloud-alibaba.version}</version>
        <type>pom</type>
        <scope>import</scope>
      </dependency>
      <dependency>
        <groupId>org.springframework.modulith</groupId>
        <artifactId>spring-modulith-bom</artifactId>
        <version>${spring-modulith.version}</version>
        <type>pom</type>
        <scope>import</scope>
      </dependency>
      <dependency>
        <groupId>org.springframework.ai</groupId>
        <artifactId>spring-ai-bom</artifactId>
        <version>${spring-ai.version}</version>
        <type>pom</type>
        <scope>import</scope>
      </dependency>
      <dependency>
        <groupId>com.baomidou</groupId>
        <artifactId>mybatis-plus-bom</artifactId>
        <version>${mybatis-plus.version}</version>
        <type>pom</type>
        <scope>import</scope>
      </dependency>

      <!-- atom 模块 -->
      <dependency>
        <groupId>cn.mindit</groupId>
        <artifactId>atom-spring-boot-starter-api</artifactId>
        <version>${revision}</version>
      </dependency>
      <dependency>
        <groupId>cn.mindit</groupId>
        <artifactId>atom-spring-boot-starter-core</artifactId>
        <version>${revision}</version>
      </dependency>
      <dependency>
        <groupId>cn.mindit</groupId>
        <artifactId>atom-spring-boot-starter-doc</artifactId>
        <version>${revision}</version>
      </dependency>
      <dependency>
        <groupId>cn.mindit</groupId>
        <artifactId>atom-spring-boot-starter-jwt</artifactId>
        <version>${revision}</version>
      </dependency>
      <dependency>
        <groupId>cn.mindit</groupId>
        <artifactId>atom-spring-boot-starter-mqtt</artifactId>
        <version>${revision}</version>
      </dependency>
      <dependency>
        <groupId>cn.mindit</groupId>
        <artifactId>atom-spring-boot-starter-mybatis-plus</artifactId>
        <version>${revision}</version>
      </dependency>
      <dependency>
        <groupId>cn.mindit</groupId>
        <artifactId>atom-spring-boot-starter-opc-da</artifactId>
        <version>${revision}</version>
      </dependency>
      <dependency>
        <groupId>cn.mindit</groupId>
        <artifactId>atom-spring-boot-starter-opc-ua</artifactId>
        <version>${revision}</version>
      </dependency>
      <dependency>
        <groupId>cn.mindit</groupId>
        <artifactId>atom-spring-boot-starter-redis</artifactId>
        <version>${revision}</version>
      </dependency>
      <dependency>
        <groupId>cn.mindit</groupId>
        <artifactId>atom-spring-boot-starter-scheduling</artifactId>
        <version>${revision}</version>
      </dependency>
      <dependency>
        <groupId>cn.mindit</groupId>
        <artifactId>atom-spring-boot-starter-scheduling-shedlock</artifactId>
        <version>${revision}</version>
      </dependency>
      <dependency>
        <groupId>cn.mindit</groupId>
        <artifactId>atom-spring-boot-starter-web</artifactId>
        <version>${revision}</version>
      </dependency>
      <dependency>
        <groupId>cn.mindit</groupId>
        <artifactId>atom-spring-boot-starter-websocket</artifactId>
        <version>${revision}</version>
      </dependency>
      <dependency>
        <groupId>cn.mindit</groupId>
        <artifactId>atom-spring-cloud-starter-consul</artifactId>
        <version>${revision}</version>
      </dependency>
      <dependency>
        <groupId>cn.mindit</groupId>
        <artifactId>atom-spring-cloud-starter-feign</artifactId>
        <version>${revision}</version>
      </dependency>
      <dependency>
        <groupId>cn.mindit</groupId>
        <artifactId>atom-spring-cloud-starter-kafka</artifactId>
        <version>${revision}</version>
      </dependency>
      <dependency>
        <groupId>cn.mindit</groupId>
        <artifactId>atom-spring-cloud-starter-nacos-config</artifactId>
        <version>${revision}</version>
      </dependency>
      <dependency>
        <groupId>cn.mindit</groupId>
        <artifactId>atom-spring-cloud-starter-nacos-discovery</artifactId>
        <version>${revision}</version>
      </dependency>

      <!-- 第三方 -->
      <dependency>
        <groupId>org.springframework.boot</groupId>
        <artifactId>spring-boot-starter-aop</artifactId>
